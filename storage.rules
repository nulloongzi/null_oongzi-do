rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 허용 contentType 헬퍼: SVG/HTML/임의 텍스트는 차단 (XSS 호스팅 방지)
    function isSafeImageType() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/png',
        'image/webp',
        'image/gif'
      ];
    }

    function isSafeSize() {
      return request.resource.size < 5 * 1024 * 1024;
    }

    // ── 인증 사진 ──
    // 읽기: 챗봇 캐러셀 썸네일에 필요 → 공개 (기존 데이터 호환)
    // 쓰기: 자신의 uid 디렉터리 아래에만 가능. 다른 팀 사진 덮어쓰기 차단.
    match /verification_photos/{allPaths=**} {
      allow read: if true;
    }
    match /verification_photos/{userId}/{fileName} {
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && isSafeImageType()
                    && isSafeSize()
                    && fileName.size() <= 100;
    }

    // ── 팀 사진 ──
    match /club_photos/{allPaths=**} {
      allow read: if true;
    }
    match /club_photos/{userId}/{fileName} {
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && isSafeImageType()
                    && isSafeSize()
                    && fileName.size() <= 100;
    }
  }
}
