rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 관리자 체크 함수: /admins/{uid} 문서 존재 여부
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 팀 문서 필드 타입·길이 검증 (doc 비대화·잘못된 타입 주입 방지).
    // 존재하는 필드에 대해서만 검사 — 부분 update(merge)도 통과.
    function clubFieldsValid() {
      let d = request.resource.data;
      return (!('name' in d) || (d.name is string && d.name.size() > 0 && d.name.size() <= 80))
          && (!('target' in d) || (d.target is string && d.target.size() <= 80))
          && (!('address' in d) || (d.address is string && d.address.size() <= 250))
          && (!('price' in d) || (d.price is string && d.price.size() <= 120))
          && (!('schedule' in d) || (d.schedule is string && d.schedule.size() <= 600))
          && (!('urgent_msg' in d) || (d.urgent_msg is string && d.urgent_msg.size() <= 250))
          && (!('contact' in d) || (d.contact is map
                && (!('insta' in d.contact) || (d.contact.insta is string && d.contact.insta.size() <= 60))
                && (!('link' in d.contact) || (d.contact.link is string && d.contact.link.size() <= 500))))
          && (!('coordinates' in d) || (d.coordinates is map
                && d.coordinates.lat is number && d.coordinates.lng is number));
    }

    // clubs: 모두 읽기, 소유자/관리자만 수정
    match /clubs/{clubId} {
      allow read: if true;

      // 새 팀 등록: 인증된 사용자가 자신을 registered_by로 기록, is_verified=false 강제, 필드 검증
      allow create: if request.auth != null
                    && request.resource.data.registered_by == request.auth.uid
                    && request.resource.data.is_verified == false
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && clubFieldsValid();

      // 업데이트: 관리자는 모든 필드(신뢰), 소유자는 is_verified/registered_by 보존 + 필드 검증
      allow update: if isAdmin()
                    || (request.auth != null
                        && resource.data.registered_by != null
                        && resource.data.registered_by == request.auth.uid
                        && request.resource.data.is_verified == resource.data.is_verified
                        && request.resource.data.registered_by == resource.data.registered_by
                        && clubFieldsValid());

      // 삭제: 관리자 또는 소유자
      allow delete: if isAdmin()
                    || (request.auth != null
                        && resource.data.registered_by == request.auth.uid);
    }

    // verification_requests: 신청자 본인/관리자만 읽기, Cloud Functions만 update
    match /verification_requests/{requestId} {
      allow read: if isAdmin()
                  || (request.auth != null
                      && resource.data.requested_by == request.auth.uid);

      allow create: if request.auth != null
                    && request.resource.data.requested_by == request.auth.uid
                    && request.resource.data.status == "pending";

      // update/delete: Cloud Functions(admin SDK)만 가능
      allow update, delete: if false;
    }

    // users: 공개 프로필 (닉네임/색상). email·bookmarks·customTeams는
    // private 서브컬렉션으로 분리하여 PIPA 위험(이메일 공개 덤프) 차단.
    match /users/{userId} {
      allow read: if true;
      // 공개 필드만 허용. lazy migration 시 비공개 필드 삭제(FieldValue.delete())로
      // 결과 키 집합이 화이트리스트에 맞춰지면 통과.
      allow write: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly([
                         'nickname', 'suffix', 'full_nickname', 'color', 'created_at'
                       ]);
    }

    // users 비공개 프로필: 본인만 읽기/쓰기
    match /users/{userId}/private/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // admins: 관리자 목록. list 금지(관리자 UID 덤프 차단), 본인 uid get만 허용.
    // 쓰기는 콘솔/admin SDK에서만.
    match /admins/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list: if false;
      allow write: if false;
    }

    // system: Cloud Functions만 접근 (토큰 캐시 등)
    match /system/{docId} {
      allow read, write: if false;
    }

    // 명시되지 않은 컬렉션은 기본적으로 차단 (catch-all 제거)
  }
}
